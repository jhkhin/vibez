<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SQL Injection 실습 하네스</title>
    <style>
        :root {
            --bg-color: #0d0208;
            --text-color: #00ff41;
            --accent-color: #008f11;
            --warn-color: #ff3e3e;
            --highlight: #ffff00;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: 'Courier New', Courier, monospace;
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        header {
            padding: 1rem;
            text-align: center;
            border-bottom: 1px solid var(--accent-color);
            background: rgba(0, 255, 65, 0.05);
        }

        .main-content {
            display: flex;
            flex: 1;
            overflow: hidden;
        }

        /* 왼쪽: 로그인 폼 */
        .login-section {
            flex: 1;
            padding: 2rem;
            border-right: 1px solid var(--accent-color);
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-card {
            max-width: 400px;
            margin: 0 auto;
            width: 100%;
        }

        .input-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: bold;
        }

        input {
            width: 100%;
            padding: 0.8rem;
            background: #000;
            border: 1px solid var(--accent-color);
            color: var(--text-color);
            font-family: inherit;
            box-sizing: border-box;
        }

        input:focus {
            outline: none;
            box-shadow: 0 0 10px var(--accent-color);
        }

        button {
            width: 100%;
            padding: 1rem;
            background: var(--accent-color);
            color: #000;
            border: none;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: var(--text-color);
            box-shadow: 0 0 20px var(--text-color);
        }

        /* 오른쪽: 쿼리 모니터 (Harness) */
        .monitor-section {
            flex: 1.2;
            padding: 2rem;
            background: #000;
            display: flex;
            flex-direction: column;
        }

        .monitor-title {
            color: #888;
            margin-bottom: 1rem;
            font-size: 0.9rem;
            text-transform: uppercase;
        }

        .sql-display {
            background: #111;
            padding: 1.5rem;
            border-radius: 5px;
            font-size: 1.2rem;
            line-height: 1.6;
            word-break: break-all;
            border-left: 4px solid var(--text-color);
        }

        .sql-kw { color: #d19a66; } /* Keyword */
        .sql-str { color: #98c379; } /* String Quotes */
        .user-payload { 
            color: var(--highlight); 
            background: rgba(255, 255, 0, 0.1);
            text-decoration: underline;
            padding: 2px 4px;
        }

        .result-box {
            margin-top: 2rem;
            padding: 1rem;
            border: 1px dashed var(--accent-color);
            min-height: 100px;
        }

        .status-msg {
            font-size: 1.1rem;
            margin-bottom: 10px;
        }

        .flag {
            color: var(--highlight);
            font-weight: bold;
            padding: 5px;
            border: 1px solid var(--highlight);
            display: inline-block;
        }

        footer {
            padding: 0.5rem;
            text-align: center;
            font-size: 0.8rem;
            color: #555;
            background: #000;
        }

        @media (max-width: 768px) {
            .main-content { flex-direction: column; overflow-y: auto; }
            .login-section { border-right: none; border-bottom: 1px solid var(--accent-color); }
        }
    </style>
</head>
<body>

<header>
    <h1>🔐 SQL Injection Lab (Harness Edition)</h1>
</header>

<div class="main-content">
    <div class="login-section">
        <div class="login-card">
            <h2>System Login</h2>
            <div class="input-group">
                <label>USER ID</label>
                <input type="text" id="username" placeholder="Enter ID" oninput="syncQuery()" autocomplete="off">
            </div>
            <div class="input-group">
                <label>PASSWORD</label>
                <input type="text" id="password" placeholder="Enter Password" oninput="syncQuery()" autocomplete="off">
            </div>
            <button onclick="attemptLogin()">AUTHENTICATE</button>
        </div>
    </div>

    <div class="monitor-section">
        <div class="monitor-title">[SERVER SIDE LOGS - SQL MONITOR]</div>
        <div class="sql-display" id="queryView">
            <span class="sql-kw">SELECT</span> * <span class="sql-kw">FROM</span> users <br>
            <span class="sql-kw">WHERE</span> id = <span class="sql-str">'</span><span class="user-payload" id="out-user"></span><span class="sql-str">'</span> <br>
            <span class="sql-kw">AND</span> pw = <span class="sql-str">'</span><span class="user-payload" id="out-pass"></span><span class="sql-str">'</span>;
        </div>

        <div class="result-box" id="resultBox">
            <div class="status-msg">Waiting for input...</div>
        </div>
        
        <div style="margin-top: auto; color: #444; font-size: 0.85rem;">
            * Tip: ' OR '1'='1 -- 와 같은 페이로드를 입력하여 논리 구조를 깨보세요.
        </div>
    </div>
</div>

<footer>
    교육용 목적으로 제작된 시뮬레이터입니다. 실제 시스템에서 허가받지 않은 공격은 불법입니다.
</footer>

<script>
    const mockDB = [
        { id: 'admin', pw: 'super_secret_p@ss_1337', flag: 'FLAG{CONGRATS_SQL_MASTER_2024}' },
        { id: 'guest', pw: 'guest123', flag: 'Welcome, guest user!' }
    ];

    function syncQuery() {
        const u = document.getElementById('username').value;
        const p = document.getElementById('password').value;
        
        document.getElementById('out-user').innerText = u;
        document.getElementById('out-pass').innerText = p;
        
        // 결과창 초기화
        const rb = document.getElementById('resultBox');
        rb.innerHTML = '<div class="status-msg">입력 대기 중...</div>';
        rb.style.borderColor = 'var(--accent-color)';
    }

    function attemptLogin() {
        const u = document.getElementById('username').value;
        const p = document.getElementById('password').value;
        const rb = document.getElementById('resultBox');

        // SQL Injection 시뮬레이션 로직
        // 실제 서버라면 이 구문이 문자열 그대로 DB에 전달되어 쿼리 구조가 변함
        let success = false;
        let userData = null;

        // 1. 정상 로그인 체크
        userData = mockDB.find(user => user.id === u && user.pw === p);
        if(userData) success = true;

        // 2. 취약점 시뮬레이션 (공격 페이로드 감지)
        // ' OR '1'='1 패턴 또는 주석처리(--) 등이 포함될 경우 성공으로 간주 (교육적 허용)
        const attackPatterns = ["' or '1'='1", "' OR '1'='1", "' or 1=1", "'--", "admin' --"];
        
        if (attackPatterns.some(ptrn => u.includes(ptrn) || p.includes(ptrn))) {
            success = true;
            userData = mockDB[0]; // 인젝션 성공 시 보통 첫 번째 레코드인 관리자로 로그인됨
        }

        if (success) {
            rb.style.borderColor = 'var(--text-color)';
            rb.innerHTML = `
                <div class="status-msg" style="color: var(--text-color)">✅ 로그인 성공! (관리자 권한 획득)</div>
                <div class="flag">SECRET_DATA: ${userData.flag}</div>
            `;
        } else {
            rb.style.borderColor = 'var(--warn-color)';
            rb.innerHTML = `<div class="status-msg" style="color: var(--warn-color)">❌ 로그인 실패: Invalid Credentials</div>`;
        }
    }

    // 초기 실행
    syncQuery();
</script>

</body>
</html>